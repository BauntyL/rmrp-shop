{
    "name": "rmrp-shop",
    "version": "1.0.0",
    "description": "RMRP Shop Application",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon --exec \"node --loader ts-node/esm\" server/index.ts",
        "test": "jest",
        "build": "npm run build:server && npm run build:client",
        "build:client": "if [ -d \"client\" ]; then cd client && npm install && npm run build; fi",
        "build:server": "npx tsc --project tsconfig.json",
        "prebuild": "npm run clean",
        "init-db": "node server/scripts/init-db.js",
        "clean": "rimraf dist",
        "prepare": "npm run build:server"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=8.0.0"
    },
    "keywords": [
        "express",
        "typescript",
        "shop",
        "api"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcrypt": "^5.1.1",
        "compression": "^1.7.4",
        "connect-pg-simple": "^9.0.1",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.21.2",
        "express-rate-limit": "^7.1.5",
        "express-session": "^1.17.3",
        "glob": "^10.3.10",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "lru-cache": "^10.1.0",
        "node-fetch": "^3.3.2",
        "passport": "^0.7.0",
        "passport-local": "^1.0.0",
        "pg": "^8.11.3",
        "rimraf": "^5.0.5",
        "winston": "^3.11.0",
        "typescript": "^5.3.3"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/express-session": "^1.17.10",
        "@types/glob": "^8.1.0",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/node": "^20.11.24",
        "@types/passport": "^1.0.16",
        "@types/passport-local": "^1.0.38",
        "@types/pg": "^8.15.2",
        "jest": "^29.7.0",
        "nodemon": "^3.1.10",
        "ts-node": "^10.9.2"
    },
    "overrides": {
        "glob": "^10.3.10",
        "rimraf": "^5.0.5"
    }
}