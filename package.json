{
  "name": "rmrp-shop",
  "version": "1.0.0",
  "description": "RMRP Shop - Российский автомобильный каталог",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "install:client": "npm install --prefix client",
    "build": "npm run build --prefix client && npx tsc --project server/tsconfig.json",
    "start": "node server.js",
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\""
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
